    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_ApiKey">API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_ApiKey_Description">API Key 획득 방법 보기</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_ApiKey_Placeholder">API Key를 입력하세요</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_ApiKey_Empty">먼저 API Key를 설정해주세요</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Model">모델</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Voice">음성</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Voice_Description">사용 가능한 음성 보기</sys:String>
