<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Url">接口地址</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Url_Placeholder">https://api.xiaomimimo.com/v1/chat/completions</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_ApiKey">API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_ApiKey_Description">点击查看如何获取API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_ApiKey_Placeholder">请输入API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_ApiKey_Empty">请先配置API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Model">模型</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Voice">音色</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Voice_Description">点击查看可用音色列表</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Style">风格</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Style_Description">支持语速控制、情绪变化、角色扮演、方言等</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Text_Empty">文本内容不能为空</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Audio_Empty">API返回的音频数据为空</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Parse_Error">解析API响应失败</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Decode_Error">音频数据解码失败</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Support">支持</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_MiMo_Support_Description">此插件基于小米MiMo语音合成API</sys:String>

</ResourceDictionary>
